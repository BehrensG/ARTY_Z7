/*
 * helloworld.c: simple test application
 *
 * This application configures UART 16550 to baud rate 9600.
 * PS7 UART (Zynq) is not initialized by this application, since
 * bootrom/bsp configures it to baud rate 115200
 *
 * ------------------------------------------------
 * | UART TYPE   BAUD RATE                        |
 * ------------------------------------------------
 *   uartns550   9600
 *   uartlite    Configurable only in HW design
 *   ps7_uart    115200 (configured by bootrom/bsp)
 */

#include <stdio.h>
#include "platform.h"
#include "xil_printf.h"
#include "xil_io.h"
#include "xgpio.h"
#include "sleep.h"


#define GPIO_DEVICE_ID		XPAR_GPIO_0_DEVICE_ID
XGpio Gpio;


int main()
{
	s32 Status = 0;
	u32 data = 0;
	float lsb = 4.096/8388608;
	float meas = 0.0;
	float gain = 1.25;

    init_platform();

    Status = XGpio_Initialize(&Gpio, GPIO_DEVICE_ID);
    if (Status != XST_SUCCESS) {
        return XST_FAILURE;
    }

    while(1){
    	/*
    	XGpio_DiscreteWrite(&Gpio,1,0x01);

    	usleep(300000);
    	XGpio_DiscreteWrite(&Gpio,1,0x00);
    	usleep(300000);
*/
    	data = Xil_In32(XPAR_AD4030_0_S00_AXI_BASEADDR + 0x14);
    	while(data != 0x00000003)
    	{
    		data = Xil_In32(XPAR_AD4030_0_S00_AXI_BASEADDR + 0x14);
    	}

    	data = Xil_In32(XPAR_AD4030_0_S00_AXI_BASEADDR + 0x18);

    	if (data & 0x00800000){
    		data = data & (~0x800000);
    		meas = -1*gain*data*lsb;
    	}
    	else{
    		meas = gain*data*lsb;
    	}
    	usleep(300000);
    }
    cleanup_platform();
    return 0;
}

